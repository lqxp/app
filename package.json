{
  "name": "qxchat",
  "version": "1.13.2",
  "description": "QxChat Client based on lqxp protocol",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "homepage": "./",
  "scripts": {
    "dev": "tauri dev",
    "start": "tauri dev",
    "build": "scripts/tauri-build.sh",
    "build:win": "tauri build --target x86_64-pc-windows-msvc",
    "build:mac": "tauri build --target universal-apple-darwin",
    "build:linux": "scripts/tauri-build.sh --bundles appimage,deb,rpm",
    "build:linux:x64": "scripts/tauri-build.sh --target x86_64-unknown-linux-gnu --bundles appimage,deb,rpm",
    "build:linux:arm64": "scripts/tauri-build.sh --target aarch64-unknown-linux-gnu --bundles appimage,deb,rpm",
    "build:android": "scripts/build-android.sh",
    "ios:init": "tauri ios init --skip-targets-install",
    "ios:dev": "scripts/ios-dev.sh",
    "ios:build": "scripts/ios-build.sh",
    "tauri": "tauri",
    "version:set": "python3 scripts/bump-version.py set",
    "patch": "python3 scripts/bump-version.py patch",
    "minor": "python3 scripts/bump-version.py minor",
    "major": "python3 scripts/bump-version.py major",
    "typecheck": "tsc --noEmit"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "2.5.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.2",
    "typescript": "^5.4.0"
  }
}
